    "image_with_text": {
      "type": "image-with-text",
      "blocks": {
        "heading": { "type": "heading", "settings": { "heading": "Fit notes", "heading_size": "h2" } },
        "text": { "type": "text", "settings": { "text": "<p>Each silhouette has its own intended ease. Tailored pieces sit close. Knits relax. Outerwear is cut to layer over a midweight knit. When you're between sizes, size down for structured cuts, size up for knits and drape.</p>" } }
      },
      "block_order": ["heading", "text"],
      "settings": {
        "color_scheme": "scheme-2",
        "image_ratio": "landscape",
        "layout": "text_first",
        "padding_top": 32,
        "padding_bottom": 48
      }
    },
    "faq": {
      "type": "collapsible-content",
      "blocks": {
        "row_1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What if I'm between sizes?",
            "row_content": "<p>Size down for structured pieces, up for knits and outerwear meant to layer.</p>"
          }
        },
        "row_2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I find my measurements?",
            "row_content": "<p>Use the guide above. If you'd like a second opinion, contact the concierge — we'll help you size from a recent garment.</p>"
          }
        },
        "row_3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I exchange for a different size?",
            "row_content": "<p>Yes. Within 30 days, unworn pieces can be exchanged or returned at no cost. See our shipping & returns policy for details.</p>"
          }
        }
