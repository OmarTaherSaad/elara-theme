    "intro": {
      "type": "rich-text",
      "blocks": {
        "heading": { "type": "heading", "settings": { "heading": "How to measure", "heading_size": "h2" } },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Measure against the body with a relaxed posture and a soft tape. For best results, wear the kind of layer you'd typically wear under the piece you're sizing.</p><p><strong>Chest:</strong> at the fullest point, across the shoulder blades. <strong>Waist:</strong> at the natural waist, where the body bends. <strong>Hip:</strong> at the fullest point of the seat.</p>"
          }
        }
      },
      "block_order": ["heading", "text"],
      "settings": {
        "color_scheme": "scheme-1",
        "full_width": false,
        "padding_top": 64,
        "padding_bottom": 32
      }
    },
    "size_table": {
      "type": "rich-text",
      "blocks": {
        "heading": { "type": "heading", "settings": { "heading": "Womenswear", "heading_size": "h3" } },
        "text": {
          "type": "text",
          "settings": {
            "text": "<table><thead><tr><th>Size</th><th>Bust (cm)</th><th>Waist (cm)</th><th>Hip (cm)</th></tr></thead><tbody><tr><td>XS</td><td>78–82</td><td>60–64</td><td>86–90</td></tr><tr><td>S</td><td>82–86</td><td>64–68</td><td>90–94</td></tr><tr><td>M</td><td>86–92</td><td>68–74</td><td>94–100</td></tr><tr><td>L</td><td>92–98</td><td>74–80</td><td>100–106</td></tr><tr><td>XL</td><td>98–104</td><td>80–86</td><td>106–112</td></tr></tbody></table>"
          }
        }
      },
      "block_order": ["heading", "text"],
      "settings": {
        "color_scheme": "scheme-1",
        "full_width": false,
        "padding_top": 16,
        "padding_bottom": 48
      }
