        "step_2": { "type": "step", "settings": { "heading": "Stitched by hand", "text": "<p>Every seam is set by hand. The thread chosen for tensile strength and aged colour.</p>" } },
        "step_3": { "type": "step", "settings": { "heading": "Worn-in by design", "text": "<p>Pre-conditioned with natural oils so the bag arrives looking already loved.</p>" } }
      },
      "block_order": ["step_1", "step_2", "step_3"],
      "settings": {
        "eyebrow": "Inside the atelier",
