        "paragraph": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Every piece begins as a swatch on the studio table. We slow down so the result doesn't have to apologise for itself. This season is a study in restraint — natural fibres, subtle palettes, and a silhouette that earns its place.</p>"
          }
        },
        "link": { "type": "link", "settings": { "label": "Read the full story", "url": "shopify://pages/about" } }
