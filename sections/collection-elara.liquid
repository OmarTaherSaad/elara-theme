{% assign per_page = section.settings.per_page | default: 24 %}
{% paginate collection.products by per_page %}
  <section class="elara-collection">
    <header class="elara-collection__header">
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="elara-collection__desc">{{ collection.description }}</div>
      {% endif %}
    </header>

    <aside class="elara-filters">
        {% render 'facets', results: collection %}
        {% comment %} uses Dawn facets if present {% endcomment %}
      </aside>      

    <div class="elara-grid">
      {% for product in collection.products %}
        <article class="elara-card">
          <a href="{{ product.url }}">
            {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', alt: product.title }}
            <h3>{{ product.title }}</h3>
            <div class="price">
              {% render 'price', product: product, use_variant: true %}
            </div>
          </a>
          {% render 'quick-add', product: product %}
        </article>
      {% endfor %}
    </div>

    {% render 'pagination', paginate: paginate %}
  </section>

  <style>
    .elara-collection {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 24px;
    }
    .elara-collection__header {
      grid-column: 1 / -1;
      margin-bottom: 8px;
    }
    .elara-filters {
      position: sticky;
      top: 72px;
      align-self: start;
      max-height: calc(100vh - 80px);
      overflow: auto;
      padding-right: 8px;
    }
    .elara-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }
    .elara-card a {
      text-decoration: none;
      color: inherit;
    }
    .elara-card img {
      width: 100%;
      height: auto;
      object-fit: cover;
      border: 1px solid #eee;
      border-radius: 8px;
    }
    .elara-qa {
      margin-top: 8px;
      width: 100%;
      height: 40px;
      border: 1px solid #111;
      background: #111;
      color: #fff;
      border-radius: 8px;
    }
    .elara-qa[disabled] {
      opacity: 0.5;
    }
    @media (max-width: 1200px) {
      .elara-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (max-width: 990px) {
      .elara-collection {
        grid-template-columns: 1fr;
      }
      .elara-filters {
        position: static;
        max-height: none;
      }
    }
  </style>
{% endpaginate %}
{% schema %}
{
  "name": "Collection · Elara",
  "settings": [
    { "type": "range", "id": "per_page", "min": 8, "max": 48, "step": 4, "label": "Products per page", "default": 24 }
  ],
  "presets": [{ "name": "Collection · Elara" }]
}
{% endschema %}
