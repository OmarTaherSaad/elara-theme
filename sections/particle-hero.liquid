{{ 'section-particle-hero.css' | asset_url | stylesheet_tag }}

<section
  class="elara-particle-hero color-{{ section.settings.color_scheme }} gradient elara-padded-section section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  data-elara-particles
  data-elara-particles-density="{{ section.settings.density }}"
  data-elara-particles-link-distance="{{ section.settings.link_distance }}"
  data-elara-particles-speed="{{ section.settings.speed }}"
  {% if section.settings.color_override != blank %}data-elara-particles-color="{{ section.settings.color_override }}"{% endif %}
  data-elara-particles-variant="{{ section.settings.variant }}"
>
  <div class="elara-particle-hero__inner page-width">
    {%- if section.settings.eyebrow != blank -%}
      {% render 'editorial-eyebrow', text: section.settings.eyebrow, divider: true %}
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="elara-display-lg elara-particle-hero__heading elara-words-reveal">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="elara-particle-hero__description rte elara-reveal-up">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a
        href="{{ section.settings.cta_link }}"
        class="button button--primary elara-particle-hero__cta"
        data-elara-magnetic
        data-elara-magnetic-strength="10"
      >
        {{ section.settings.cta_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Particle hero",
  "tag": "section",
  "class": "section section--particle-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Connected by craft"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A studio without distance"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Every piece travels through the same set of hands. Cut from cloth selected weeks before it arrives. Finished in the studio.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Read our process"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Particle network"
    },
    {
      "type": "range",
      "id": "density",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 60,
      "label": "Dot density"
    },
    {
      "type": "range",
      "id": "link_distance",
      "min": 60,
      "max": 240,
      "step": 10,
      "default": 140,
      "label": "Link distance (px)",
      "info": "How close two dots must be to draw a connecting line."
    },
    {
      "type": "range",
      "id": "speed",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 18,
      "label": "Drift speed",
      "info": "Higher = livelier movement (×0.01)."
    },
    {
      "type": "color",
      "id": "color_override",
      "label": "Particle color (optional)",
      "info": "Defaults to the theme foreground color."
    },
    {
      "type": "select",
      "id": "variant",
      "options": [
        { "value": "default",  "label": "Default" },
        { "value": "subtle",   "label": "Subtle" },
        { "value": "luminous", "label": "Luminous (over dark hero)" }
      ],
      "default": "default",
      "label": "Visual variant"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "Particle hero"
    }
  ]
}
{% endschema %}
