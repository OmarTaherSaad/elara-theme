{% schema %}
{
  "name": "Header · Elara",
  "settings": [{ "type": "checkbox", "id": "sticky", "label": "Sticky header", "default": true }],
  "blocks": [
    { "type": "menu", "name": "Menu", "settings": [
      { "type": "link_list", "id": "menu", "label": "Menu" },
      { "type": "image_picker", "id": "image", "label": "Mega image" },
      { "type": "text", "id": "tagline", "label": "Tagline" }
    ]}
  ],
  "max_blocks": 6,
  "default": { "blocks": [{ "type": "menu" }] }
}
{% endschema %}

<header class="elara-header{% if section.settings.sticky %} is-sticky{% endif %}">
  <div class="elara-header__row">
    <a href="{{ routes.root_url }}" class="elara-logo" aria-label="{{ shop.name }}">
      <img src="{{ 'elara-logo.webp' | asset_url }}" alt="Elara" width="140" height="28" loading="eager" fetchpriority="high">
    </a>
    {% render 'currency-switcher' %}
    <nav class="elara-nav" role="navigation">
      {% for block in section.blocks %}
        {% if block.settings.menu %}
          <div class="elara-nav__item">
            {{ block.settings.menu | linklist }}
            {% if block.settings.image %}
              <div class="elara-mega">
                <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="" width="1000" height="600" loading="lazy">
                {% if block.settings.tagline %}<p class="elara-mega__tag">{{ block.settings.tagline }}</p>{% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </nav>
  </div>
</header>

<style>
.elara-header{position:relative;padding:12px 16px;border-bottom:1px solid #eee;background:#fff}
.elara-header.is-sticky{position:sticky;top:0;z-index:50}
.elara-header__row{display:flex;align-items:center;gap:16px}
.elara-nav__item{position:relative}
.elara-mega{display:none;position:absolute;left:0;top:100%;background:#fff;box-shadow:0 10px 30px rgba(0,0,0,.08);padding:16px;min-width:640px}
.elara-nav__item:hover .elara-mega{display:block}
.elara-mega__tag{margin-top:8px;font-size:14px;color:#666}
@media (max-width: 990px){.elara-mega{position:static;display:block;box-shadow:none;padding:8px}}
</style>
