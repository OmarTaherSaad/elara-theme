{{ 'section-marquee.css' | asset_url | stylesheet_tag }}
<script src="{{ 'marquee-scroll.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign speed_class = 'elara-marquee--speed-normal'
  case section.settings.speed
    when 'slow'
      assign speed_class = 'elara-marquee--speed-slow'
    when 'fast'
      assign speed_class = 'elara-marquee--speed-fast'
  endcase

  assign direction_class = 'elara-marquee--ltr'
  if section.settings.direction == 'rtl'
    assign direction_class = 'elara-marquee--rtl'
  endif

  assign style_class = ''
  if section.settings.font_style == 'italic'
    assign style_class = 'elara-marquee--italic'
  endif
-%}

<elara-marquee
  class="elara-marquee color-{{ section.settings.color_scheme }} gradient {{ speed_class }} {{ direction_class }} {{ style_class }} elara-marquee--{{ section.settings.mode }}{% if section.settings.border_top %} elara-marquee--border-top{% endif %}{% if section.settings.border_bottom %} elara-marquee--border-bottom{% endif %}"
  data-pause-on-hover="{{ section.settings.pause_on_hover }}"
>
  <div class="elara-marquee__viewport">
    {%- capture items_html -%}
      {%- if section.settings.mode == 'logos' -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' and block.settings.image != blank -%}
            <li class="elara-marquee__item elara-marquee__item--logo" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="elara-marquee__logo-link">
              {%- endif -%}
              {{
                block.settings.image
                | image_url: width: 320
                | image_tag:
                  loading: 'lazy',
                  class: 'elara-marquee__logo',
                  widths: '120, 180, 240, 320',
                  sizes: '180px',
                  alt: block.settings.image.alt
              }}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'text' and block.settings.text != blank -%}
            <li class="elara-marquee__item elara-marquee__item--text" {{ block.shopify_attributes }}>
              <span class="elara-marquee__text">{{ block.settings.text | escape }}</span>
              {%- if block.settings.separator != blank -%}
                <span class="elara-marquee__separator" aria-hidden="true">{{ block.settings.separator }}</span>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {% render 'marquee-track', items_html: items_html, aria_label: section.settings.aria_label %}
  </div>
</elara-marquee>

{% schema %}
{
  "name": "Marquee",
  "tag": "section",
  "class": "section section--marquee",
  "max_blocks": 16,
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "options": [
        { "value": "text",  "label": "Text" },
        { "value": "logos", "label": "Logos" }
      ],
      "default": "text",
      "label": "Mode"
    },
    {
      "type": "select",
      "id": "speed",
      "options": [
        { "value": "slow",   "label": "Slow" },
        { "value": "normal", "label": "Normal" },
        { "value": "fast",   "label": "Fast" }
      ],
      "default": "slow",
      "label": "Scroll speed"
    },
    {
      "type": "select",
      "id": "direction",
      "options": [
        { "value": "ltr", "label": "Left to right" },
        { "value": "rtl", "label": "Right to left" }
      ],
      "default": "rtl",
      "label": "Scroll direction"
    },
    {
      "type": "select",
      "id": "font_style",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "italic",  "label": "Italic display" }
      ],
      "default": "italic",
      "label": "Text style",
      "info": "Only applies to text mode."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "default": true,
      "label": "Pause on hover"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "border_top",
      "default": true,
      "label": "Show top border"
    },
    {
      "type": "checkbox",
      "id": "border_bottom",
      "default": true,
      "label": "Show bottom border"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessible label",
      "default": "Promotional marquee",
      "info": "Announced by screen readers."
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New season"
        },
        {
          "type": "text",
          "id": "separator",
          "label": "Trailing separator",
          "default": "·",
          "info": "Decorative glyph shown after each text item."
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "text", "settings": { "text": "New season" } },
        { "type": "text", "settings": { "text": "Atelier 02" } },
        { "type": "text", "settings": { "text": "Shipping worldwide" } },
        { "type": "text", "settings": { "text": "Personal styling" } }
      ]
    }
  ]
}
{% endschema %}
