{%- comment -%}
  Cart drawer recommendations.

  Rendered inline at the bottom of the cart drawer. Falls back to a curated
  collection (settings.cart_drawer_collection) when no per-product
  recommendations are available. The section is intentionally lightweight so
  it can also be hot-swapped via the Section Rendering API on cart updates
  (e.g. fetch('/?section_id=cart-recommendations&product_id=...')).
{%- endcomment -%}
{{ 'component-card-editorial.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign rec_products = empty
  if recommendations.products_count > 0
    assign rec_products = recommendations.products
  elsif settings.cart_drawer_collection != blank
    assign rec_products = settings.cart_drawer_collection.products
  endif
-%}

{%- if rec_products != empty and rec_products.size > 0 -%}
  <aside class="elara-cart-drawer__recommendations" aria-labelledby="CartRecommendations-Heading">
    <p class="elara-cart-drawer__recommendations-heading" id="CartRecommendations-Heading">
      {{ section.settings.heading | default: 'You may also like' }}
    </p>
    <ul class="elara-cart-drawer__recommendations-track list-unstyled">
      {%- for rec in rec_products limit: section.settings.products_to_show -%}
        <li class="elara-cart-drawer__recommendations-item">
          {% render 'card-product-editorial',
            card_product: rec,
            media_aspect_ratio: 'portrait',
            show_vendor: false,
            show_secondary_image: false,
            sizes: '14rem'
          %}
        </li>
      {%- endfor -%}
    </ul>
  </aside>
{%- endif -%}

{% schema %}
{
  "name": "Cart recommendations",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ]
}
{% endschema %}
