{{ 'section-press-strip.css' | asset_url | stylesheet_tag }}

<section
  class="elara-press-strip color-{{ section.settings.color_scheme }} gradient elara-padded-section section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
>
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      {% render 'section-header',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        alignment: 'center'
      %}
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul
        class="elara-press-strip__logos list-unstyled"
        style="--elara-press-logo-height: {{ section.settings.logo_height }}px;"
      >
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' and block.settings.image != blank -%}
            <li class="elara-press-strip__item{% if block.settings.link != blank %} elara-press-strip__item--link{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="elara-press-strip__link" aria-label="{{ block.settings.image.alt | default: block.settings.alt | escape }}">
              {%- endif -%}
              {{
                block.settings.image
                | image_url: width: 360
                | image_tag:
                  loading: 'lazy',
                  class: 'elara-press-strip__logo',
                  widths: '120, 180, 240, 360',
                  sizes: '180px',
                  alt: block.settings.image.alt | default: block.settings.alt
              }}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.quote != blank -%}
      <figure class="elara-press-strip__quote">
        <blockquote class="elara-press-strip__quote-text">{{ section.settings.quote | escape }}</blockquote>
        {%- if section.settings.attribution != blank -%}
          <figcaption class="elara-press-strip__quote-attribution">&mdash; {{ section.settings.attribution | escape }}</figcaption>
        {%- endif -%}
      </figure>
    {%- endif -%}
  </div>
</section>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Press strip",
  "tag": "section",
  "class": "section section--press-strip",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "As featured in"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Quote"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Pull quote"
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution"
    },
    {
      "type": "header",
      "content": "Logo display"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Logo height",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "logo_grayscale",
      "default": true,
      "label": "Grayscale logos",
      "info": "Logos display in monochrome; restore color on hover."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text fallback",
          "info": "Used if the image has no alt attribute."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press strip",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
