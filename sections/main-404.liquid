{{ 'section-404-editorial.css' | asset_url | stylesheet_tag }}

<div class="template-404 elara-404 page-width">
  <div class="elara-404__inner">
    <p class="elara-eyebrow">{{ 'templates.404.eyebrow' | t }}</p>
    <h1 class="elara-display-lg elara-404__title">
      {{ 'templates.404.title' | t }}
    </h1>
    <p class="elara-404__subtext">
      {{ 'templates.404.subtext' | t }}
    </p>
    <div class="elara-404__actions">
      <a href="{{ routes.root_url }}" class="button">
        {{ 'templates.404.back_home' | t }}
      </a>
      <a href="{{ routes.all_products_collection_url }}" class="elara-link">
        {{ 'general.continue_shopping' | t }}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404 page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
